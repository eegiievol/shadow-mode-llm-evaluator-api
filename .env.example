# DigitalOcean Serverless Inference API
# Create a model access key: DO Console -> Agent Platform -> Serverless Inference -> Model access keys
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_INFERENCE_API_KEY=

# Models to compare (Primary serves users; Candidate runs in shadow).
# Model availability depends on your account's subscription tier. List the
# models your key can call with:
#   curl -s https://inference.do-ai.run/v1/models -H "Authorization: Bearer $KEY" | jq '.data[].id'
# The pair below is a verified-working cross-family combo (see docs/REQUIREMENTS.md).
PRIMARY_MODEL=llama3.3-70b-instruct
CANDIDATE_MODEL=deepseek-3.2

# Timeouts (seconds)
PRIMARY_TIMEOUT=30
CANDIDATE_TIMEOUT=10

# Shadow pool: bounded concurrency + load shedding
SHADOW_QUEUE_SIZE=100
SHADOW_WORKERS=4
# Percentage of traffic mirrored to the candidate (0-100); runtime-adjustable via PUT /config
SHADOW_PERCENTAGE=100

# SQLite file for persisting mismatched payloads
SQLITE_PATH=traces.db
